---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getPostUrl } from "@/utils/getPostPaths";
import { getCategoryPosts, learningPaths } from "@/data/portal";
import config from "@/config";

const { socials, posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const researchPosts = getCategoryPosts(sortedPosts, "Research");
const thoughtPosts = getCategoryPosts(sortedPosts, "Thoughts");
const featuredResearch = researchPosts.filter(({ data }) => data.featured);
const latestThoughts = thoughtPosts.slice(0, 3);
const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section
      id="hero"
      class="border-border relative overflow-hidden border-b pt-10 pb-10 sm:pt-16"
    >
      <div
        class="from-accent/20 pointer-events-none absolute top-6 right-0 h-48 w-48 rounded-full bg-radial to-transparent blur-2xl"
      >
      </div>
      <div class="mb-6 flex flex-wrap items-center gap-3 text-sm">
        <span class="border-border bg-muted/35 rounded-full border px-3 py-1">
          AI engineering notebook
        </span>
        <a
          href={getRelativeLocaleUrl(locale, "search")}
          class="border-border hover:border-accent rounded-full border px-3 py-1"
        >
          Search <kbd class="text-muted-foreground ms-1">/</kbd>
        </a>
      </div>

      <h1 class="max-w-2xl text-4xl leading-tight font-bold sm:text-6xl">
        Anshuman Patnaik
      </h1>

      <p class="mt-4 max-w-3xl text-xl leading-8 font-medium sm:text-2xl">
        Notes on AI Systems, Reinforcement Learning, Inference Engineering,
        Computer Vision, Agents, and Semiconductors.
      </p>

      <p class="text-muted-foreground mt-5 max-w-2xl text-lg leading-8">
        A public engineering notebook where I document concepts, paper
        implementations, experiments, and thoughts on the evolution of AI
        systems.
      </p>

      <div class="mt-7 flex flex-wrap items-center gap-4">
        <LinkButton
          href={getRelativeLocaleUrl(locale, "posts")}
          class="bg-accent text-accent-foreground rounded-full px-5 py-2.5 font-medium no-underline hover:opacity-90"
        >
          Start Reading
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
        <LinkButton
          href={getRelativeLocaleUrl(locale, "research")}
          class="border-border hover:border-accent rounded-full border px-5 py-2.5 font-medium no-underline"
        >
          Explore Research
        </LinkButton>
        <a
          target="_blank"
          href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`}
          class="hover:text-accent inline-flex items-center gap-2"
          aria-label="RSS Feed"
          title="RSS Feed"
        >
          <IconRss width={18} height={18} class="stroke-accent stroke-3" />
          <span>RSS</span>
        </a>
      </div>

      {
        socials.length > 0 && (
          <div class="mt-8 flex max-sm:flex-col sm:items-center">
            <div class="text-muted-foreground me-2 mb-1 whitespace-nowrap sm:mb-0">
              Find me:
            </div>
            <Socials />
          </div>
        )
      }
    </section>

    <section id="learning-paths" class="border-border border-b py-10">
      <div class="mb-6 flex items-end justify-between gap-4">
        <div>
          <p class="text-muted-foreground text-sm">Learning Paths</p>
          <h2 class="text-2xl font-semibold tracking-wide">
            Structured topic areas
          </h2>
        </div>
        <LinkButton
          href={getRelativeLocaleUrl(locale, "learning-paths")}
          class="hover:text-accent text-sm font-medium"
        >
          View all
          <IconArrowRight class="inline-block size-4 rtl:-rotate-180" />
        </LinkButton>
      </div>

      <ul class="grid gap-3 sm:grid-cols-2">
        {
          learningPaths.map(path => {
            const count = getCategoryPosts(sortedPosts, path.title).length;
            return (
              <li>
                <a
                  href={getRelativeLocaleUrl(
                    locale,
                    `learning-paths#${path.slug}`
                  )}
                  class="border-border hover:border-accent hover:bg-muted/30 group block rounded-lg border p-4"
                >
                  <div class="flex items-start justify-between gap-4">
                    <span class="text-accent text-sm font-semibold">
                      {path.accent}
                    </span>
                    <IconArrowRight class="size-4 transition-transform group-hover:translate-x-1 rtl:-rotate-180" />
                  </div>
                  <h3 class="mt-3 text-lg font-semibold">{path.title}</h3>
                  <p class="text-muted-foreground mt-2 text-sm leading-6">
                    {path.description}
                  </p>
                  <p class="text-muted-foreground mt-3 text-sm">
                    {count} articles
                  </p>
                </a>
              </li>
            );
          })
        }
      </ul>
    </section>

    <section id="recent-posts" class="border-border border-b py-10">
      <div class="mb-6 flex items-end justify-between gap-4">
        <div>
          <p class="text-muted-foreground text-sm">Recent Articles</p>
          <h2 class="text-2xl font-semibold tracking-wide">
            Latest technical notes
          </h2>
        </div>
        <LinkButton
          href={getRelativeLocaleUrl(locale, "posts")}
          class="hover:text-accent text-sm font-medium"
        >
          All articles
          <IconArrowRight class="inline-block size-4 rtl:-rotate-180" />
        </LinkButton>
      </div>

      <ul class="divide-border divide-y">
        {
          sortedPosts
            .slice(0, postsConfig.perIndex)
            .map(({ id, data, filePath }) => (
              <li class="py-4 first:pt-0">
                <a
                  href={getPostUrl(id, filePath, locale)}
                  class="hover:text-accent group block"
                >
                  <div class="flex items-baseline justify-between gap-4">
                    <h3 class="text-lg font-medium">{data.title}</h3>
                    <IconArrowRight class="size-4 shrink-0 transition-transform group-hover:translate-x-1 rtl:-rotate-180" />
                  </div>
                  <p class="text-muted-foreground mt-1">{data.description}</p>
                  {data.category && (
                    <p class="text-accent mt-2 text-sm">{data.category}</p>
                  )}
                </a>
              </li>
            ))
        }
      </ul>
    </section>

    <section id="research" class="border-border border-b py-10">
      <div class="mb-6 flex items-end justify-between gap-4">
        <div>
          <p class="text-muted-foreground text-sm">Featured Research Notes</p>
          <h2 class="text-2xl font-semibold tracking-wide">
            Papers, experiments, findings
          </h2>
        </div>
        <LinkButton
          href={getRelativeLocaleUrl(locale, "research")}
          class="hover:text-accent text-sm font-medium"
        >
          Research
          <IconArrowRight class="inline-block size-4 rtl:-rotate-180" />
        </LinkButton>
      </div>

      <ul class="grid gap-3 sm:grid-cols-2">
        {
          (featuredResearch.length ? featuredResearch : researchPosts)
            .slice(0, 2)
            .map(({ id, data, filePath }) => (
              <li>
                <a
                  href={getPostUrl(id, filePath, locale)}
                  class="border-border hover:border-accent hover:bg-muted/30 block rounded-lg border p-4"
                >
                  <h3 class="text-lg font-semibold">{data.title}</h3>
                  <p class="text-muted-foreground mt-2 text-sm leading-6">
                    {data.description}
                  </p>
                </a>
              </li>
            ))
        }
      </ul>
    </section>

    <section id="thoughts" class="py-10">
      <div class="mb-6 flex items-end justify-between gap-4">
        <div>
          <p class="text-muted-foreground text-sm">Latest Thoughts</p>
          <h2 class="text-2xl font-semibold tracking-wide">
            Industry and infrastructure essays
          </h2>
        </div>
        <LinkButton
          href={getRelativeLocaleUrl(locale, "thoughts")}
          class="hover:text-accent text-sm font-medium"
        >
          Thoughts
          <IconArrowRight class="inline-block size-4 rtl:-rotate-180" />
        </LinkButton>
      </div>

      <ul class="divide-border divide-y">
        {
          latestThoughts.map(({ id, data, filePath }) => (
            <li>
              <a
                href={getPostUrl(id, filePath, locale)}
                class="hover:text-accent flex items-center justify-between gap-4 py-4 first:pt-0"
              >
                <span>
                  <span class="block font-medium">{data.title}</span>
                  <span class="text-muted-foreground mt-1 block text-sm">
                    {data.description}
                  </span>
                </span>
                <IconArrowRight class="size-4 shrink-0 rtl:-rotate-180" />
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
