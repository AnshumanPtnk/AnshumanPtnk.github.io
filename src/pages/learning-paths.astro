---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Main from "@/components/Main.astro";
import { learningPaths, getCategoryPosts } from "@/data/portal";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getPostUrl } from "@/utils/getPostPaths";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const posts = getSortedPosts(await getCollection("posts"));
---

<Layout
  title={`Learning Paths | ${config.site.title}`}
  description="Structured topic areas for public AI engineering notes."
>
  <Header />

  <Main
    pageTitle="Learning Paths"
    pageDesc="Structured areas for building intuition across AI systems, research, and infrastructure."
  >
    <div class="space-y-10">
      {
        learningPaths.map(path => {
          const pathPosts = getCategoryPosts(posts, path.title);
          return (
            <section id={path.slug} class="scroll-mt-8">
              <div class="border-border bg-muted/20 rounded-lg border p-5">
                <div class="flex flex-wrap items-start justify-between gap-4">
                  <div>
                    <p class="text-accent text-sm font-semibold">
                      {path.accent}
                    </p>
                    <h2 class="mt-2 text-2xl font-semibold">{path.title}</h2>
                    <p class="text-muted-foreground mt-2 max-w-2xl leading-7">
                      {path.description}
                    </p>
                  </div>
                  <a
                    href={getRelativeLocaleUrl(locale, `tags/${path.slug}`)}
                    class="border-border hover:border-accent rounded-full border px-3 py-1 text-sm"
                  >
                    Tag
                  </a>
                </div>

                <ul class="divide-border mt-5 divide-y">
                  {pathPosts.map(({ id, data, filePath }) => (
                    <li class="py-4 first:pt-0">
                      <a
                        href={getPostUrl(id, filePath, locale)}
                        class="hover:text-accent group block"
                      >
                        <div class="flex items-center justify-between gap-4">
                          <h3 class="font-medium">{data.title}</h3>
                          <IconArrowRight class="size-4 shrink-0 transition-transform group-hover:translate-x-1 rtl:-rotate-180" />
                        </div>
                        <p class="text-muted-foreground mt-1 text-sm leading-6">
                          {data.description}
                        </p>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </section>
          );
        })
      }
    </div>
  </Main>

  <Footer />
</Layout>
